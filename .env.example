# URL du Worker analytics (proxifié par Nitro sous /api). Server-only.
# Override runtime de runtimeConfig.workerBaseUrl (convention NUXT_ + camelCase).
NUXT_WORKER_BASE_URL=

# Better Auth (server-only)
# Secret de signature des sessions — générer avec : openssl rand -base64 32
NUXT_BETTER_AUTH_SECRET=
# URL de base de l'app (http://localhost:3000 en dev, domaine de prod ensuite)
NUXT_BETTER_AUTH_URL=
