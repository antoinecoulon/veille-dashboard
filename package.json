{
  "name": "veille-dashboard",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "auth:generate": "npx @better-auth/cli generate --config scripts/auth-generate.ts --output migrations/0001_better_auth.sql -y",
    "db:migrate:local": "wrangler d1 migrations apply veille-auth --local",
    "db:migrate:remote": "wrangler d1 migrations apply veille-auth --remote"
  },
  "dependencies": {
    "@nuxt/ui": "^4.9.0",
    "better-auth": "^1.6.23",
    "chart.js": "^4.5.1",
    "nuxt": "^4.4.8",
    "tailwindcss": "^4.3.1",
    "vue": "^3.5.35",
    "vue-chartjs": "^5.3.3",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260708.1",
    "@iconify-json/lucide": "^1.2.114",
    "@types/node": "^26.0.0",
    "nitro-cloudflare-dev": "^0.2.2",
    "wrangler": "^4.108.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@parcel/watcher", "esbuild", "workerd"]
  }
}
