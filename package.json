{
  "name": "veille-dashboard",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "typecheck": "nuxt typecheck",
    "lint": "eslint .",
    "test": "tsc --noEmit -p tsconfig.test.json && vitest run",
    "postinstall": "nuxt prepare",
    "auth:generate": "npx @better-auth/cli generate --config scripts/auth-generate.ts --output migrations/0001_better_auth.sql -y",
    "db:migrate:local": "wrangler d1 migrations apply veille-auth --local",
    "db:migrate:remote": "wrangler d1 migrations apply veille-auth --remote"
  },
  "dependencies": {
    "@nuxt/ui": "^4.9.0",
    "better-auth": "^1.6.23",
    "chart.js": "^4.5.1",
    "nuxt": "^4.4.8",
    "tailwindcss": "^4.3.1",
    "vue": "^3.5.35",
    "vue-chartjs": "^5.3.3",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260708.1",
    "@iconify-json/lucide": "^1.2.114",
    "@nuxt/eslint": "^1.16.0",
    "@types/node": "^26.0.0",
    "@vite-pwa/nuxt": "^1.1.1",
    "eslint": "^10.7.0",
    "nitro-cloudflare-dev": "^0.2.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10",
    "vue-tsc": "^3.3.7",
    "wrangler": "^4.108.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "workerd"
    ],
    "overrides": {
      "typescript": "6.0.3",
      "esbuild@>=0.27.3 <0.28.1": ">=0.28.1",
      "brace-expansion@>=2.0.0 <2.1.2": ">=2.1.2",
      "minimatch>brace-expansion": "5.0.7",
      "tar@<=7.5.18": ">=7.5.19",
      "shell-quote@<=1.8.4": ">=1.9.0",
      "sharp": ">=0.35.0",
      "svgo@>=4.0.0 <4.0.2": ">=4.0.2",
      "fast-uri@>=3.0.0 <=3.1.3": ">=3.1.4"
    }
  }
}
