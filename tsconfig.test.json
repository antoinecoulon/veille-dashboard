{
  // Contrôle de types des tests, hors projet Nuxt.
  //
  // `nuxt typecheck` ne regarde pas `test/` : ses projets générés n'incluent que `app/`,
  // `server/`, `shared/**/*.d.ts` et `test/nuxt/**` (tests destinés au runtime Nuxt). Sans ce
  // fichier, la liaison de type de `test/contrat-health.test.ts` ne serait jamais compilée —
  // donc inerte, alors qu'elle est précisément le filet posé contre la dérive de contrat
  // consignée en ADR D18. Un garde-fou qu'on ne compile pas n'est pas un garde-fou.
  //
  // Projet autonome et non extension du tsconfig Nuxt : les fichiers visés n'utilisent aucun
  // auto-import ni type généré (`server/utils/relais.ts` a été écrit sans dépendance au
  // runtime pour cette raison). Il n'y a donc rien à hériter, et rien qui casse si `.nuxt/`
  // n'a pas encore été généré.
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ESNext"],
    "module": "Preserve",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "verbatimModuleSyntax": true
  },
  "include": [
    "test/**/*.ts",
    "shared/types/**/*.ts",
    "server/utils/relais.ts"
  ]
}
